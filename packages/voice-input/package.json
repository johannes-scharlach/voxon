{
  "name": "@voxon/voice-input",
  "version": "0.1.0",
  "description": "React hooks for real-time voice transcription with Voxon + Mistral Voxtral. Streaming capture, two-phase stop, and a prompt input controller for the live-transcript UX.",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johannes-scharlach/voxon.git",
    "directory": "packages/voice-input"
  },
  "homepage": "https://github.com/johannes-scharlach/voxon#readme",
  "bugs": "https://github.com/johannes-scharlach/voxon/issues",
  "scripts": {
    "build": "tsc",
    "lint": "biome check",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@types/react": ">=18",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "keywords": [
    "voxon",
    "mistral",
    "voxtral",
    "voice",
    "transcription",
    "speech-to-text",
    "realtime",
    "react",
    "audio-worklet"
  ],
  "devDependencies": {
    "@types/react": "^19.2.17",
    "typescript": "^6.0.3",
    "vitest": "^4"
  }
}
